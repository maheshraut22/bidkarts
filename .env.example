# =============================================================================
# BidKarts Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# For local development with Docker Compose:
DATABASE_URL=postgresql://bidkarts:bidkarts_dev_password@localhost:5432/bidkarts

# For AWS RDS (replace with your RDS endpoint after running deploy-aws.sh):
# DATABASE_URL=postgresql://bidkarts:YOUR_DB_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/bidkarts?sslmode=require

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── JWT Secret (MUST be changed in production - min 32 chars) ─────────────────
JWT_SECRET=bidkarts-secret-key-change-this-in-production-min-32-chars!!

# ── SendGrid Email (optional - for real email notifications) ──────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=noreply@bidkarts.com

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── AWS Configuration (for deploy script) ─────────────────────────────────────
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ── Docker Compose Settings ───────────────────────────────────────────────────
POSTGRES_PASSWORD=bidkarts_dev_password
APP_PORT=3000
PGADMIN_PASSWORD=admin123
