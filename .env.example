# =============================================================================
# BidKarts - Environment Variables Template
# Copy this file to .env for local development
# NEVER commit .env to git!
# =============================================================================

# ── Node / Server ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Local development (Docker):
DATABASE_URL=postgresql://bidkarts:bidkarts_dev_password@localhost:5432/bidkarts

# AWS RDS (production) — replace with your RDS endpoint:
# DATABASE_URL=postgresql://bidkarts:YOUR_DB_PASSWORD@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/bidkarts

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SMTP_FROM=noreply@bidkarts.com

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com/app/keys
# Leave blank to run in simulation mode
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── OAuth (optional) ─────────────────────────────────────────────────────────
# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth - https://developers.facebook.com/apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── AWS (for production deployment) ──────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=

# ── App Settings ──────────────────────────────────────────────────────────────
APP_NAME=bidkarts
APP_URL=http://localhost:3000
