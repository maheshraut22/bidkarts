# Docker build context exclusions
# Keeps the build context small and fast

# Dependencies (reinstalled in Docker)
node_modules/
npm-debug.log*

# Build outputs
dist/
dist-server/

# Local environment files (secrets must not enter image)
.env
.env.*
!.env.example

# Cloudflare / Wrangler local state
.wrangler/
.dev.vars

# Git
.git/
.gitignore

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
pids/
*.pid

# PM2
.pm2/

# Deploy state files (generated by deploy script)
.deploy-state-*.json
.env.aws.*.generated

# Test files
*.test.ts
*.spec.ts
__tests__/
coverage/

# Documentation (not needed in image)
*.md
!README.md
