{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bidkarts",
  "compatibility_date": "2026-03-07",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bidkarts-production",
      "database_id": "placeholder-id"
    }
  ]
}
