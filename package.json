{
  "name": "bidkarts",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "tsx server.ts",
    "start:prod": "NODE_ENV=production tsx server.ts",
    "dev:node": "tsx watch server.ts",
    "dev:sandbox": "npm run build && wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "preview": "wrangler pages dev dist",
    "deploy:cf": "npm run build && wrangler pages deploy dist --project-name bidkarts",
    "deploy:aws": "bash scripts/deploy-aws.sh",
    "redeploy:aws": "bash scripts/redeploy.sh",
    "setup:local": "bash scripts/setup-local.sh",
    "db:migrate": "psql $DATABASE_URL -f migrations/001_initial_schema.sql",
    "db:seed": "curl -s http://localhost:3000/api/setup | jq .",
    "docker:build": "docker build -t bidkarts .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "tsc:server": "npx tsc --project tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "dotenv": "^17.3.1",
    "hono": "^4.12.5",
    "jose": "^5.10.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
